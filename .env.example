# Telegram bot token (@BotFather)
BOT_TOKEN=

# MongoDB connection URI
DB_URI=mongodb://localhost:27017/filmdasizbot

# Xatoliklar yuboriladigan kanal/chat ID (masalan: -1001234567890)
ERROR_CHANNEL=

# Webhook domeni (production, app.js uchun). Masalan: https://example.com
SERVER_URL=

# Webhook porti (default 5000)
PORT=5000

# Admin foydalanuvchi ID lari, vergul bilan ajratilgan. Masalan: 12345,67890
ADMIN_IDS=
